import uuid
import re
import os
import glob

# Módulo vitalia-medical-catalog
root_path = r'f:\PROJECTOS\JAVA\VITALIA\workspace\amachi-platform\vitalia-medical-catalog\src\main\resources\db\migration'
files = glob.glob(os.path.join(root_path, "V9_*__insert_*.sql"))

def update_sql_file(file_path):
    print(f"Processing: {os.path.basename(file_path)}")
    if not os.path.exists(file_path):
        return

    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()

    # Find the INSERT header columns
    # We look for something like INSERT INTO TABLE (cols) VALUES
    match = re.search(r'INSERT INTO (\w+) \((.*?)\) VALUES', content, re.IGNORECASE | re.DOTALL)
    if not match:
        print(f"  - No match found for INSERT statement in {os.path.basename(file_path)}")
        return

    table_name = match.group(1)
    cols_text = match.group(2)
    
    # Split columns by comma
    cols = [c.strip() for c in cols_text.split(',')]
    
    # Check if VERSION already exists to avoid double update
    if 'VERSION' in cols:
        print(f"  - File already contains VERSION column, skipping.")
        return

    # Update Header: Add VERSION and EXTERNAL_ID at the end
    new_cols_text = cols_text + ', VERSION, EXTERNAL_ID'
    content = content.replace(f"({cols_text})", f"({new_cols_text})")

    # Pattern for values: (val1, val2, ...); or (val1, val2, ...),
    # We need to be careful with strings containing parentheses or commas.
    # A common pattern for values lines: ( 'val', 'val', ... )[,;]
    
    def replace_values(val_match):
        val_line = val_match.group(0).strip()
        # Find the last closing parenthesis and what follows (, or ;)
        # We assume values are in format ( ... )[,;]
        if val_line.endswith(';'):
            inner = val_line[1:-2]
            suffix = ');'
        elif val_line.endswith(','):
            inner = val_line[1:-2]
            suffix = '),'
        else:
            # Fallback if it's just one line/different format
            inner = val_line[1:-1]
            suffix = ')'

        new_uuid = str(uuid.uuid4())
        return f"({inner.strip()}, 0, '{new_uuid}'){suffix}"

    # Regex for one set of values: (\s*\(.*?\)[,;])
    # Note: This is a bit naive for very complex nested values but good for standard inserts.
    # We use re.DOTALL to handle multiline values if any.
    
    # Let's find all value blocks and update them.
    # We look for blocks starting with ( after VALUES
    
    parts = content.split('VALUES', 1)
    if len(parts) < 2:
        return
    
    header = parts[0]
    values_part = parts[1]
    
    # Updated regex to match ( ... ) , or ( ... ) ;
    # We use a non-greedy match to catch each record individually.
    # Handling strings requires a more robust split, but for these simple catalogs:
    # re.sub(r'(\s*\(.*?\)[,;])', replace_values, values_part, flags=re.DOTALL)
    
    # Improved regex to handle quotes slightly better (naive)
    new_values_part = re.sub(r'(\s*\(.*?\)(?=[,;]))', replace_values, values_part, flags=re.DOTALL)
    
    # Fix the last one if it didn't match the comma/semicolon lookahead correctly
    # Actually the lookahead above is fine. 
    # Let's use a simpler approach for standard inserts:
    
    content = header + "VALUES" + new_values_part

    with open(file_path, 'w', encoding='utf-8') as f:
        f.write(content)
    print(f"  - Successfully updated.")

for f in files:
    update_sql_file(f)

print("\nDone! All insert scripts in vitalia-medical-catalog/db/migration have been updated with VERSION and EXTERNAL_ID.")
